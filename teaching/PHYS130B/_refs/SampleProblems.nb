Notebook[{

Cell[CellGroupData[{
Cell["Problem 1", "Subsubsection",ExpressionUUID->"53eae17f-35a0-4ba3-a16f-5f221a63b4a2"],

Cell[TextData[{
 "Consider a qubit initially prepared in state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SuperscriptBox["\[Sigma]", "x"], "=", 
       RowBox[{"+", "1"}]}]},
    "Ket",
    DisplayFunction->(StyleBox[
      RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}], 
      AutoSpacing -> False]& )], TraditionalForm]],ExpressionUUID->
  "9126a950-fc75-4367-ae45-6c55e9cebf8b"],
 ", evolving under the Hamiltonian ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "=", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", "2"]}], 
     SuperscriptBox[
      OverscriptBox["\[Sigma]", "^"], "z"]}]}], TraditionalForm]],
  ExpressionUUID->"d0a33ac3-371c-4aea-a201-f4020b170a2a"],
 " for time ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "=", 
    RowBox[{"\[Pi]", "/", "3"}]}], TraditionalForm]],ExpressionUUID->
  "6a5e1c26-80d2-4710-8f02-b9bdcd4d5eda"],
 " (assuming ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[HBar]", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "8f07c410-c7d6-40ee-8f17-00f67288e4ac"],
 "), what should be the expectation values ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"\[LeftAngleBracket]", 
      SuperscriptBox["\[Sigma]", "x"], "\[RightAngleBracket]"}], ",", 
     RowBox[{"\[LeftAngleBracket]", 
      SuperscriptBox["\[Sigma]", "y"], "\[RightAngleBracket]"}], ",", 
     RowBox[{"\[LeftAngleBracket]", 
      SuperscriptBox["\[Sigma]", "z"], "\[RightAngleBracket]"}]}], ")"}], 
   TraditionalForm]],ExpressionUUID->"33ceb116-be94-4042-a2c1-f467f8f71fbb"],
 " for the final state?"
}], "TextIndent",ExpressionUUID->"f0a85cbf-af36-448a-8d6b-afad605a013e"],

Cell[TextData[{
 "(A) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", "2"], ",", 
     FractionBox[
      SqrtBox["3"], "2"], ",", "0"}], ")"}], TraditionalForm]],ExpressionUUID->
  "2f5bff60-e1bd-462d-acb8-1c29ae6ff4d5"]
}], "TextNoIndent",ExpressionUUID->"0f43aebb-c1de-49f0-a937-5fb253724d01"],

Cell[TextData[{
 "(B) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", "2"]}], ",", 
     FractionBox[
      SqrtBox["3"], "2"], ",", "0"}], ")"}], TraditionalForm]],ExpressionUUID->
  "5213d05b-23b1-46e8-8943-6dcbfff55f4f"]
}], "TextNoIndent",ExpressionUUID->"81cbc078-1335-47a4-9b6c-4d678071402f"],

Cell[TextData[{
 "(C) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     FractionBox["1", "2"], ",", 
     RowBox[{"-", 
      FractionBox[
       SqrtBox["3"], "2"]}], ",", "0"}], ")"}], TraditionalForm]],
  ExpressionUUID->"0a57af3d-defc-41ee-a7ed-78689755f386"]
}], "TextNoIndent",ExpressionUUID->"d81c353c-c5c0-4180-9062-2162aa074784"],

Cell[TextData[{
 "(D) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", 
    RowBox[{
     RowBox[{"-", 
      FractionBox["1", "2"]}], ",", 
     RowBox[{"-", 
      FractionBox[
       SqrtBox["3"], "2"]}], ",", "0"}], ")"}], TraditionalForm]],
  ExpressionUUID->"2f1e648a-1b68-4b71-84e3-f272316e6f0f"]
}], "TextNoIndent",ExpressionUUID->"e7153b39-4993-473e-b66f-240c13bd9f5d"],

Cell[CellGroupData[{

Cell["Answer:", "Subsubsubsection",ExpressionUUID->"b5be2129-8d3e-4f68-87f4-21bcea58fcec"],

Cell["(C)", "TextNoIndent",ExpressionUUID->"3fb3d71c-40a5-4b27-be95-90134d3598a3"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Problem 2", "Subsubsection",ExpressionUUID->"40da6a1a-4243-4734-bbcc-539905710702"],

Cell[TextData[{
 "Consider a spin-1 particle initially prepared in the state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"1", ",", 
       RowBox[{"+", "1"}]}]},
    "Ket",
    DisplayFunction->(StyleBox[
      RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}], 
      AutoSpacing -> False]& )], TraditionalForm]],ExpressionUUID->
  "1693347e-5d65-40af-86ec-26ce15cbccd7"],
 " (as ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"j", ",", "m"}]},
    "Ket",
    DisplayFunction->(StyleBox[
      RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}], 
      AutoSpacing -> False]& )], TraditionalForm]],ExpressionUUID->
  "96a22856-7736-4b9e-8791-bf885ddf4323"],
 " labeled by the angular momentum quantum numbers ",
 Cell[BoxData[
  FormBox["j", TraditionalForm]],ExpressionUUID->
  "8f0ab916-df83-4851-b112-f789e0f61e3c"],
 " and ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],ExpressionUUID->
  "91cf6532-1c2e-419f-9fa7-2c74f5c8cea1"],
 "). Let ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox[
     StyleBox["J",
      FontWeight->"Bold"], "^"], "=", 
    RowBox[{"(", 
     RowBox[{
      SubscriptBox[
       OverscriptBox["J", "^"], "1"], ",", 
      SubscriptBox[
       OverscriptBox["J", "^"], "2"], ",", 
      SubscriptBox[
       OverscriptBox["J", "^"], "3"]}], ")"}]}], TraditionalForm]],
  ExpressionUUID->"5c56fefe-3e56-40ce-a7ec-e2399714073b"],
 " be the spin angular momentum operator for the particle. The particle first \
evolves under the Hamiltonian ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "=", 
    SubscriptBox[
     OverscriptBox["J", "^"], "1"]}], TraditionalForm]],
  InitializationCell->True,ExpressionUUID->
  "a9509fac-b719-4d2e-86ee-3533920b96a0"],
 " for time ",
 Cell[BoxData[
  FormBox[
   RowBox[{"t", "=", 
    RowBox[{"\[Pi]", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "407e5baa-9b59-4814-9757-ea9f3c98a182"],
 " (assuming ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[HBar]", "=", "1"}], TraditionalForm]],ExpressionUUID->
  "41059742-0c64-4f8a-88d2-b156c349d570"],
 "), and then gets measured by the observable ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox[
    OverscriptBox["J", "^"], "3", "2"], TraditionalForm]],ExpressionUUID->
  "b4d120a7-f210-4e12-ae32-d9a89e619bf8"],
 ". The measurement outcome is observed to be ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["J", "3", "2"], "=", "1"}], TraditionalForm]],
  ExpressionUUID->"8ee7a039-ae36-4fbc-bb56-bce95487ca93"],
 ". What is the expectation value of the ",
 Cell[BoxData[
  FormBox[
   SubscriptBox[
    OverscriptBox["J", "^"], "3"], TraditionalForm]],ExpressionUUID->
  "8d75c4b1-a679-4960-8b61-298258b2ddb6"],
 " observable in the post-measurement final state?"
}], "TextIndent",ExpressionUUID->"f1bea927-75f3-4ac7-b31f-292d52866c24"],

Cell[TextData[{
 "(A) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"+", "1"}], TraditionalForm]],ExpressionUUID->
  "5a3202be-1d76-48b4-a75e-fcc5466f7b6d"]
}], "TextNoIndent",ExpressionUUID->"76e3d26b-ea81-4ad2-848a-6ddcf876e714"],

Cell[TextData[{
 "(B) ",
 Cell[BoxData[
  FormBox["0", TraditionalForm]],ExpressionUUID->
  "2599de40-53ac-49c3-a55f-99de46e2f632"]
}], "TextNoIndent",ExpressionUUID->"ebf2ecad-40a3-407a-a4be-3c9aa21700db"],

Cell[TextData[{
 "(C) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], TraditionalForm]],ExpressionUUID->
  "ce86eeda-9454-4369-808d-b76a033b0fba"]
}], "TextNoIndent",ExpressionUUID->"406499c7-3ad4-4823-882f-071c35276c2a"],

Cell["(D) None of the above", "TextNoIndent",ExpressionUUID->"cb3ace1c-04a2-4e70-a077-a1fbeb5c5dc3"],

Cell[CellGroupData[{

Cell["Answer:", "Subsubsubsection",ExpressionUUID->"5e8397d0-de29-4b33-86ab-4ae9dde073bd"],

Cell["(B)", "TextNoIndent",ExpressionUUID->"75971b18-b726-4590-93cf-37c5541425ec"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["1. Tilted Infinite Well (10pt)", "Subsubsection",ExpressionUUID->"2cf1f9e8-8cdb-4039-b955-8d76a59b4611"],

Cell[TextData[{
 "A particle of mass ",
 Cell[BoxData[
  FormBox["m", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "6057c656-bd5d-4e4b-b25f-20fd4d197abd"],
 " is confined in a one-dimensional infinite square well of width ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "2f233516-d52e-4c00-bf0a-a0f5fbdb6fd0"],
 ". The unperturbed Hamiltonian is given by"
}], "TextIndent",ExpressionUUID->"fc0fb0bf-f20c-4e51-953e-410c68205299"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox[
    OverscriptBox["H", "^"], "0"], "=", 
   RowBox[{
    RowBox[{"-", 
     FractionBox[
      SuperscriptBox["\[HBar]", "2"], 
      RowBox[{"2", "m"}]]}], 
    RowBox[{
     SubsuperscriptBox["\[PartialD]", "x", "2"], 
     RowBox[{"+", 
      RowBox[{
       SubscriptBox["V", "0"], "(", "x", ")"}]}]}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"a2011d8a-a174-\
47e5-a91b-b5da1695f1de"],

Cell["with", "TextNoIndent",ExpressionUUID->"192262db-d397-46e5-8ecc-f0e6b485576c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["V", "0"], "(", "x", ")"}], "=", 
   TagBox[GridBox[{
      {"\[Piecewise]", GridBox[{
         {
          RowBox[{"0", ","}], 
          RowBox[{
           RowBox[{"0", "<", "x", "<", "a"}], ","}]},
         {
          RowBox[{
           RowBox[{"+", "\[Infinity]"}], ","}], 
          RowBox[{"otherwise", "."}]}
        },
        AllowedDimensions->{2, Automatic},
        Editable->True,
        GridBoxAlignment->{
         "Columns" -> {{Left}}, "ColumnsIndexed" -> {}, 
          "Rows" -> {{Baseline}}, "RowsIndexed" -> {}},
        GridBoxItemSize->{
         "Columns" -> {{Automatic}}, "ColumnsIndexed" -> {}, "Rows" -> {{1.}},
           "RowsIndexed" -> {}},
        GridBoxSpacings->{"Columns" -> {
            Offset[0.27999999999999997`], {
             Offset[0.84]}, 
            Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, 
          "Rows" -> {
            Offset[0.2], {
             Offset[0.4]}, 
            Offset[0.2]}, "RowsIndexed" -> {}},
        Selectable->True]}
     },
     GridBoxAlignment->{
      "Columns" -> {{Left}}, "ColumnsIndexed" -> {}, "Rows" -> {{Baseline}}, 
       "RowsIndexed" -> {}},
     GridBoxItemSize->{
      "Columns" -> {{Automatic}}, "ColumnsIndexed" -> {}, "Rows" -> {{1.}}, 
       "RowsIndexed" -> {}},
     GridBoxSpacings->{"Columns" -> {
         Offset[0.27999999999999997`], {
          Offset[0.35]}, 
         Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
         Offset[0.2], {
          Offset[0.4]}, 
         Offset[0.2]}, "RowsIndexed" -> {}}],
    "Piecewise",
    DeleteWithContents->True,
    Editable->False,
    SelectWithContents->True,
    Selectable->False,
    StripWrapperBoxes->True]}], TraditionalForm]], "DisplayFormulaNumbered",Ex\
pressionUUID->"5644c6bb-81db-480f-9cd8-f78fac5e6f7a"],

Cell["\<\
We now add a small \[OpenCurlyDoubleQuote]tilted\[CloseCurlyDoubleQuote] \
(linear) potential perturbation inside the well:\
\>", "TextNoIndent",ExpressionUUID->"9f7e8164-35c8-4afb-9615-3bae5dc44c8e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"V", "(", "x", ")"}], "=", 
    RowBox[{"\[Lambda]", " ", "x"}]}], ",", "     ", 
   RowBox[{"0", "<=", "x", "<=", "a"}], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"0c00d0cb-6a28-\
4f47-8550-61aa44467198"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "4869e46e-3856-4cc8-b397-64093786832a"],
 " is a small real constant. The total Hamiltonian is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    OverscriptBox["H", "^"], "=", 
    RowBox[{
     SubscriptBox[
      OverscriptBox["H", "^"], "0"], "+", 
     OverscriptBox["V", "^"]}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1fb1e4e3-5347-4937-b47a-fb3ba668d0be"],
 "."
}], "TextNoIndent",ExpressionUUID->"007c1cc5-e6bc-47bc-97e0-70b58430cdb4"],

Cell[TextData[{
 "(i) (2pt) Write down the normalized unperturbed eigenstate wavefunction ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Psi]", "n", 
     RowBox[{"(", "0", ")"}]], "(", "x", ")"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "bf0c8e8b-18e3-4ef9-8f6c-2df4ec96584b"],
 " and eigenenergies ",
 Cell[BoxData[
  FormBox[
   SubsuperscriptBox["E", "n", 
    RowBox[{"(", "0", ")"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "cf0b0ead-acd2-4adc-a933-8ca8b80f62cf"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "=", "1"}], ",", "2", ",", "3", ",", "\[Ellipsis]"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "88f7f8dc-9a63-487e-8dd8-14a854fefced"],
 ". "
}], "TextNoIndent",ExpressionUUID->"9d995146-cfc7-4d24-8ad8-9961258010a5"],

Cell["Define", "TextNoIndent",ExpressionUUID->"3b5e1e56-c8d0-4066-a3e9-458087cea658"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["V", 
    RowBox[{"m", "\[InvisibleComma]", "n"}]], "=", 
   RowBox[{
    RowBox[{
     TemplateBox[{
       SubsuperscriptBox["\[Psi]", "m", 
        RowBox[{"(", "0", ")"}]]},
      "Bra",
      DisplayFunction->(StyleBox[
        RowBox[{"\[LeftAngleBracket]", #, "\[RightBracketingBar]"}], 
        AutoSpacing -> False, SpanMaxSize -> 1]& )], 
     OverscriptBox["V", "^"], 
     TemplateBox[{
       SubsuperscriptBox["\[Psi]", "n", 
        RowBox[{"(", "0", ")"}]]},
      "Ket",
      DisplayFunction->(StyleBox[
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}], 
        AutoSpacing -> False, SpanMaxSize -> 1]& )]}], "=", 
    RowBox[{"\[Lambda]", 
     RowBox[{
      SubsuperscriptBox["\[Integral]", "0", "a"], 
      RowBox[{
       RowBox[{
        SubsuperscriptBox["\[Psi]", "m", 
         RowBox[{"(", "0", ")"}]], "(", "x", ")"}], "x", 
       RowBox[{
        SubsuperscriptBox["\[Psi]", "n", 
         RowBox[{"(", "0", ")"}]], "(", "x", ")"}], 
       RowBox[{
        RowBox[{"\[DifferentialD]", "x"}], "."}]}]}]}]}]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"4b07a093-b0a4-4b33-\
8803-e5fab18a98dc"],

Cell[TextData[{
 "(ii) (4pt) Compute the matrix elements ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", 
    RowBox[{"m", "\[InvisibleComma]", "n"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "b32a03bf-9def-4917-9260-e6ccedabaa3d"],
 " for"
}], "TextNoIndent",ExpressionUUID->"b8afa869-5bef-43d7-8c24-b4d37a46df0d"],

Cell[TextData[{
 "(2pt) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", 
    RowBox[{"n", "=", "1"}]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "10acc38d-98af-4ce5-ab14-68be47c9cb21"],
 " (i.e. ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", "11"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "d097deaf-1d0a-4d5d-acb6-8540d6bf6f40"],
 "),"
}], "Item",ExpressionUUID->"20a2e398-4947-46c3-85e0-5c03dad1288e"],

Cell[TextData[{
 "(2pt) ",
 Cell[BoxData[
  FormBox[
   RowBox[{"m", "=", "1"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "dcc5afe9-600c-47fd-8e1f-5b5f2997e250"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "\[GreaterEqual]", "2"}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "936716e3-67fe-4da5-98f3-1aa5f2456fb1"],
 ", (i.e. ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["V", 
    RowBox[{"1", "\[InvisibleComma]", "n"}]], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "7efd2d39-d3a6-4d53-9b15-a5788c9bcc1d"],
 ")."
}], "Item",ExpressionUUID->"89b8f254-266e-46ad-8473-3c21582518d5"],

Cell[TextData[{
 "(iii) (4pt) Use non-degenerate perturbation theory to calculate the \
correction to ground state energy to the 2nd order in ",
 Cell[BoxData[
  FormBox["\[Lambda]", TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "1f566558-ed28-4656-b2eb-d44600e69beb"],
 "."
}], "TextNoIndent",ExpressionUUID->"d33c6111-b999-4c79-90da-e51e98b4f905"],

Cell[CellGroupData[{

Cell["Solution", "HiddenSupplementary",ExpressionUUID->"38d9a6f4-e373-42c6-90df-69ae88099c77"],

Cell["(i) Unperturbed wavefunctions and energies:", "TextNoIndent",ExpressionUUID->"6fb55c98-bc8c-47fb-835b-9a1b63328930"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox["\[Psi]", "n", 
     RowBox[{"(", "n", ")"}]], "=", 
    RowBox[{
     SqrtBox[
      FractionBox["2", "a"]], 
     RowBox[{"sin", "(", 
      FractionBox[
       RowBox[{"n", " ", "\[Pi]", " ", "x"}], "a"], ")"}]}]}], ",", "   ", 
   RowBox[{"0", "\[LessEqual]", "x", "\[LessEqual]", "a"}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"9de445f9-4ff6-4e74-\
ac38-2ff18cf49b5c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubsuperscriptBox["E", "n", 
     RowBox[{"(", "n", ")"}]], "=", 
    FractionBox[
     RowBox[{
      SuperscriptBox["\[HBar]", "2"], 
      SuperscriptBox["\[Pi]", "2"], 
      SuperscriptBox["n", "2"]}], 
     RowBox[{"2", "m", " ", 
      SuperscriptBox["a", "2"]}]]}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"ad094329-3568-49cf-\
be2e-4d8d4198a23a"],

Cell[TextData[{
 "for ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"n", "=", "1"}], ",", "2", ",", "3", ",", "\[Ellipsis]"}], 
   TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "ae11a68c-30f8-44a7-b6a7-c6e9b8144b1a"],
 "."
}], "TextNoIndent",ExpressionUUID->"2c6777fa-30f3-4c99-9b80-3754cf034ed2"],

Cell["(ii) Matrix elements", "TextNoIndent",ExpressionUUID->"b2608a6b-7617-43f3-813a-c1ddf991a86f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["V", "11"], "=", 
    FractionBox[
     RowBox[{"\[Lambda]", " ", "a"}], "2"]}], ","}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"e558e93c-6bd3-4e1e-\
8d38-cbb056607bc5"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["V", 
    RowBox[{"1", "\[InvisibleComma]", "n"}]], "=", 
   RowBox[{
    TagBox[GridBox[{
       {"\[Piecewise]", GridBox[{
          {
           RowBox[{
            RowBox[{"-", 
             FractionBox[
              RowBox[{"8", "\[Lambda]", " ", "a"}], 
              SuperscriptBox["\[Pi]", "2"]]}], 
            FractionBox["n", 
             SuperscriptBox[
              RowBox[{"(", 
               RowBox[{
                SuperscriptBox["n", "2"], "-", "1"}], ")"}], "2"]]}], 
           RowBox[{"n", "\[Element]", "even"}]},
          {"0", 
           RowBox[{"n", "\[Element]", "odd"}]}
         },
         AllowedDimensions->{2, Automatic},
         Editable->True,
         GridBoxAlignment->{
          "Columns" -> {{Left}}, "ColumnsIndexed" -> {}, 
           "Rows" -> {{Baseline}}, "RowsIndexed" -> {}},
         GridBoxItemSize->{
          "Columns" -> {{Automatic}}, "ColumnsIndexed" -> {}, 
           "Rows" -> {{1.}}, "RowsIndexed" -> {}},
         GridBoxSpacings->{"Columns" -> {
             Offset[0.27999999999999997`], {
              Offset[0.84]}, 
             Offset[0.27999999999999997`]}, "ColumnsIndexed" -> {}, "Rows" -> {
             Offset[0.2], {
              Offset[0.4]}, 
             Offset[0.2]}, "RowsIndexed" -> {}},
         Selectable->True]}
      },
      GridBoxAlignment->{
