Cell["(iii) Ground state energy correction", "TextNoIndent",ExpressionUUID->"cf126f47-8898-4f34-b243-b361330c26ec"],

Cell[BoxData[{
 FormBox[
  RowBox[{
   SubscriptBox["E", "1"], "\[TildeTilde]", 
   RowBox[{
    SubsuperscriptBox["E", "1", 
     RowBox[{"(", "0", ")"}]], "+", 
    SubsuperscriptBox["E", "1", 
     RowBox[{"(", "1", ")"}]], "+", 
    SubsuperscriptBox["E", "1", 
     RowBox[{"(", "2", ")"}]], "+", "\[Ellipsis]"}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    SubsuperscriptBox["E", "1", 
     RowBox[{"(", "0", ")"}]], "+", 
    SubscriptBox["V", "11"], "+", 
    RowBox[{
     UnderoverscriptBox["\[Sum]", 
      RowBox[{"n", "=", "2"}], "\[Infinity]"], 
     FractionBox[
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        SubscriptBox["V", 
         RowBox[{"1", "\[InvisibleComma]", "n"}]], "\[RightBracketingBar]"}], 
       "2"], 
      RowBox[{
       SubsuperscriptBox["E", "1", 
        RowBox[{"(", "0", ")"}]], "-", 
       SubsuperscriptBox["E", "n", 
        RowBox[{"(", "0", ")"}]]}]]}], "+", "\[Ellipsis]"}]}], 
  TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["\[HBar]", "2"], 
      SuperscriptBox["\[Pi]", "2"]}], 
     RowBox[{"2", "m", " ", 
      SuperscriptBox["a", "2"]}]], "+", 
    FractionBox[
     RowBox[{"\[Lambda]", " ", "a"}], "2"], "-", 
    RowBox[{
     FractionBox[
      RowBox[{"128", "m", " ", 
       SuperscriptBox["a", "4"], 
       SuperscriptBox["\[Lambda]", "2"]}], 
      RowBox[{
       SuperscriptBox["\[HBar]", "2"], 
       SuperscriptBox["\[Pi]", "6"]}]], 
     RowBox[{
      UnderoverscriptBox["\[Sum]", 
       RowBox[{"n", "=", "2"}], "\[Infinity]"], 
      FractionBox[
       SuperscriptBox["n", "2"], 
       SuperscriptBox[
        RowBox[{"(", 
         RowBox[{
          SuperscriptBox["n", "2"], "-", "1"}], ")"}], "5"]]}]}], "+", 
    "\[Ellipsis]"}]}], TraditionalForm], "\[IndentingNewLine]", 
 FormBox[
  RowBox[{"=", 
   RowBox[{
    FractionBox[
     RowBox[{
      SuperscriptBox["\[HBar]", "2"], 
      SuperscriptBox["\[Pi]", "2"]}], 
     RowBox[{"2", "m", " ", 
      SuperscriptBox["a", "2"]}]], "+", 
    FractionBox[
     RowBox[{"\[Lambda]", " ", "a"}], "2"], "-", 
