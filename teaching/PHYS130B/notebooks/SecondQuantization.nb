Cell[CellGroupData[{

Cell["Side Remark: Identical Particle as a Symmetry", "Subsubsubsection",ExpressionUUID->"b3a04f84-32a1-440d-98ce-2209d2bc75bc"],

Cell[TextData[{
 StyleBox["A philosophical question", "TextConcreteIndent"],
 ": how do we know if two particles are identical or not?"
}], "TextIndent",ExpressionUUID->"5a1cbecb-4b23-4f87-bfa6-9aab171ffe9f"],

Cell[CellGroupData[{

Cell[TextData[{
 "Whether two particles are identical or not is ",
 StyleBox["not",
  FontSlant->"Italic"],
 " a property associated to the particles themselves, by a property of the ",
 StyleBox["quantum dynamics",
  FontSlant->"Italic"],
 " of the particles."
}], "Item",ExpressionUUID->"58dfae9c-7297-44b6-b903-268f241c777a"],

Cell[TextData[{
 StyleBox["Rule", "TextConcreteNoIndent"],
 ": if two particles ",
 StyleBox["can",
  FontWeight->"Bold"],
 " (",
 StyleBox["can not",
  FontWeight->"Bold"],
 ") transform to each other in the quantum dynamics, they should be \
considered as ",
 StyleBox["identical",
  FontWeight->"Bold"],
 " (",
 StyleBox["distinct",
  FontWeight->"Bold"],
 ")."
}], "Item",ExpressionUUID->"736e4f88-dd89-4d73-9bb6-e5f27016cc18"],

Cell["\<\
So the distinguishability of particles depends on the conservation of the \
identity of the particle, which is a symmetry of the quantum dynamics.\
\>", "Item",ExpressionUUID->"a764c8aa-cd4e-4266-aae7-8a0460f63068"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Bosonic and Fermionic States", "Subsubsection",ExpressionUUID->"542ae8db-0bd5-4be7-8e3a-46809e0e3648"],

Cell[TextData[{
 "The ",
 StyleBox["bosonic",
  FontSlant->"Italic"],
 " and ",
 StyleBox["fermionic",
  FontSlant->"Italic"],
 " many-body states only span a ",
 StyleBox["subspace",
  FontSlant->"Italic"],
 " of the many-body Hilbert space (of distinct particles). Starting from a \
generic basis state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"[", "\[Alpha]", "]"}]},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"0a6a3bed-35a6-4586-9663-e6035c180bc1"],
 ", we can pick out (or construct) the ",
 StyleBox["basis states",
  FontWeight->"Bold"],
 " for the ",
 StyleBox["bosonic",
  FontSlant->"Italic"],
 " and ",
 StyleBox["fermionic",
  FontSlant->"Italic"],
 " subspaces:"
}], "TextIndent",ExpressionUUID->"af2e5715-c0b5-4525-8c4c-c438f1cf2211"],

Cell[CellGroupData[{

Cell[TextData[{
 "construct ",
 StyleBox["bosonic",
  FontWeight->"Bold"],
 " states by ",
 StyleBox["symmetrization",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"1859a7e2-ac6d-41d6-8465-b30389f376e0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"\[ScriptCapitalS]", 
      TemplateBox[{
        RowBox[{"[", "\[Alpha]", "]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}], 
     "\[Congruent]", 
     RowBox[{
      UnderscriptBox["\[Sum]", 
       RowBox[{"\[Pi]", "\[Element]", 
        SubscriptBox["S", "N"]}]], 
      TemplateBox[{
        RowBox[{"[", 
          SubscriptBox["\[Alpha]", "\[Pi]"], "]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}]}], 
    "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"\[Pi]", "\[Element]", 
       SubscriptBox["S", "N"]}]], 
     RowBox[{
      TemplateBox[{
        SubscriptBox["\[Alpha]", 
         RowBox[{"\[Pi]", "(", "1", ")"}]]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
      "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["\[Alpha]", 
         RowBox[{"\[Pi]", "(", "2", ")"}]]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
      "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
      TemplateBox[{
        SubscriptBox["\[Alpha]", 
         RowBox[{"\[Pi]", "(", "N", ")"}]]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}]}]}],
    ","}], TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "eq: 3845993496320827985",ExpressionUUID->"0f911d14-5523-4568-ac65-\
0c9612456d91"],

Cell[TextData[{
 "construct ",
 StyleBox["fermionic",
  FontWeight->"Bold"],
 " states by ",
 StyleBox["antisymmetrization",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"0ae1b510-2911-4e82-b4ed-21973a627a20"],

