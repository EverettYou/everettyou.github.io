             "\[RightAngleBracket]"}]& )]}]}], ")"}], "."}]}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"622d16c8-6393-\
41ab-9053-36fec60ee66a"],

Cell["\<\
Note the difference between bosonic and fermionic Fock states (even if their \
occupation numbers are the same). Here are more examples\
\>", "ItemParagraph",ExpressionUUID->"fa7db996-59af-4dd7-a694-c467ba4e097e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["2", "\[Alpha]"], ",", 
         SubscriptBox["1", "\[Beta]"]}]},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], "B"], 
    "=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox["3"]], 
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        TemplateBox[{"\[Alpha]"},
         "Ket",
         DisplayFunction->(
          RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
        "\[CircleTimes]", 
        TemplateBox[{"\[Alpha]"},
         "Ket",
         DisplayFunction->(
          RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
        "\[CircleTimes]", 
        TemplateBox[{"\[Beta]"},
         "Ket",
         DisplayFunction->(
          RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}], 
       "+", 
       RowBox[{
        TemplateBox[{"\[Alpha]"},
         "Ket",
         DisplayFunction->(
          RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
        "\[CircleTimes]", 
        TemplateBox[{"\[Beta]"},
         "Ket",
         DisplayFunction->(
          RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
        "\[CircleTimes]", 
        TemplateBox[{"\[Alpha]"},
         "Ket",
         DisplayFunction->(
          RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}], 
       "+", 
       RowBox[{
        TemplateBox[{"\[Beta]"},
         "Ket",
         DisplayFunction->(
