Cell[TextData[{
 "It corresponds to the ",
 StyleBox["tensor product unit",
  FontSlant->"Italic"],
 " in the first-quantization, which can be written as"
}], "ItemParagraph",ExpressionUUID->"292be0d7-e48a-46c9-ba1e-e557d6d3f622"],

