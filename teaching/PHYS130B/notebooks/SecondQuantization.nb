  ExpressionUUID->"68faf94b-71f7-4972-9205-6f2f9b077248"],
 " by the following rules:"
}], "TextNoIndent",ExpressionUUID->"a248b32b-b2ec-4bbc-bd3e-59a0d513174e"],

