  "8702a509-b35d-48d5-90ca-da1c2a48d5e0"],
 ") or antisymmetrization (",
 Cell[BoxData[
  FormBox["-", TraditionalForm]],ExpressionUUID->
  "d71d5640-1dca-430d-bc9a-e66b3e4cfe8d"],
 ") is implemented."
}], "TextNoIndent",ExpressionUUID->"b44a87c7-d191-47a6-a19c-dc22e1e15337"]
}, Open  ]],

