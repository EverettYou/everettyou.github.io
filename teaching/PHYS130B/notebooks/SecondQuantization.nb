 StyleBox["non-zero",
  FontSlant->"Italic"],
 " occupation number is a ",
 StyleBox["single-mode Fock state",
  FontWeight->"Bold"],
 ", denoted as"
}], "Item",ExpressionUUID->"9d151264-5882-47f7-840b-c6e1fea234e0"],

