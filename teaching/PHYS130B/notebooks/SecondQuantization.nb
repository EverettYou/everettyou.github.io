     RowBox[{"\[Alpha]", "\[VeryThinSpace]", "\[Beta]"}]]}], 
   TraditionalForm]],ExpressionUUID->"cd57725c-3305-4c34-aff3-90721418fe19"],
 " if ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Alpha]"},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"d09b59d8-fb15-4d07-a10a-b930d454de70"],
