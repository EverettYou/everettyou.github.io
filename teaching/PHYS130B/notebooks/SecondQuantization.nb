Cell["Representation of Fock States", "Subsubsection",ExpressionUUID->"d60a1d20-a634-47ff-9dbd-f468a36eb864"],

Cell[TextData[{
 "The ",
 StyleBox["first",
  FontWeight->"Bold"],
 "- and the ",
 StyleBox["second",
  FontWeight->"Bold"],
 "-",
 StyleBox["quantization",
  FontWeight->"Bold"],
 " formalisms can both provide ",
 StyleBox["legitimate",
  FontSlant->"Italic"],
 " description of identical particles. (The first-quantization is just \
awkward to use, but it is still valid.)"
}], "TextIndent",ExpressionUUID->"858e7e94-31a9-49ca-bf46-1d85d954bd3d"],

Cell[TextData[{
 "Every ",
 StyleBox["Fock state",
  FontSlant->"Italic"],
 " has a ",
