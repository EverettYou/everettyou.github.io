47d6-93d1-27b7886be6bd"],

Cell[TextData[{
 "We use a subscript ",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "e278eba1-019e-4b0a-aa05-12d618b6337c"],
 "/",
 Cell[BoxData[
  FormBox["F", TraditionalForm]],ExpressionUUID->
  "c55ef290-35ca-437c-9850-9f354eb1d80d"],
 " to indicate whether the Fock state is ",
 StyleBox["bosonic",
  FontWeight->"Bold"],
 " (",
 Cell[BoxData[
  FormBox["B", TraditionalForm]],ExpressionUUID->
  "b0251beb-4e87-4030-8183-2d2923a92591"],
 ") or ",
 StyleBox["fermionic",
  FontWeight->"Bold"],
 " (",
 Cell[BoxData[
  FormBox["F", TraditionalForm]],ExpressionUUID->
  "f0adaf47-8a51-4854-ba5b-eb715ce32001"],
 "). For vacuum state, there is no difference between them."
}], "ItemParagraph",ExpressionUUID->"0ac4516a-e49d-4635-93cf-32dc6cd04d0c"],

Cell[TextData[{
