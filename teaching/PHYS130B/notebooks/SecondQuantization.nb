Cell[CellGroupData[{

Cell["Creation and Annihilation Operators", "Subsection",ExpressionUUID->"dcd8cace-708e-4a34-8886-a1a9f3ae07a6"],

Cell[CellGroupData[{

Cell["State Insertion and Deletion", "Subsubsection",ExpressionUUID->"37fc0e3a-a99e-41fa-a340-99916549487e"],

Cell[TextData[{
 "The ",
 StyleBox["creation",
  FontWeight->"Bold"],
 " and ",
 StyleBox["annihilation operators",
  FontWeight->"Bold"],
 " are introduced to ",
 StyleBox["create",
  FontSlant->"Italic"],
 " and ",
 StyleBox["annihilate",
  FontSlant->"Italic"],
 " particles in the quantum many-body system, as indicated by their names. \
The first step towards defining them is to understand how to ",
 StyleBox["insert",
  FontSlant->"Italic"],
 " and ",
 StyleBox["delete",
  FontSlant->"Italic"],
 " a single-particle state from the first-quantized state in a ",
 StyleBox["symmetric",
  FontSlant->"Italic"],
 " (or ",
 StyleBox["antisymmetric",
  FontSlant->"Italic"],
 ") manner."
}], "TextIndent",ExpressionUUID->"8e321999-d4cd-4297-9e5c-497f722206bf"],

Cell["Let us first declare some notations:", "TextIndent",ExpressionUUID->"7adefa4d-f7af-446a-bed0-016f07d0a32a"],

Cell[CellGroupData[{

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Alpha]"},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"28f44ac2-8f8b-4ccf-8399-bbafad38b7a8"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Beta]"},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"692497e5-dc15-4575-9158-3344d54188a6"],
 " be single-particle states."
}], "Item",ExpressionUUID->"6a86d662-5787-4a03-8e8e-108fcbcdb9e3"],

Cell[TextData[{
 "Let \[ScriptOne] be the ",
 StyleBox["tensor identity",
  FontSlant->"Italic"],
 " (meaning that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     TemplateBox[{"\[Alpha]"},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
     "\[CircleTimes]", "\[ScriptOne]"}], "=", 
    RowBox[{
     RowBox[{"\[ScriptOne]", "\[CircleTimes]", 
      TemplateBox[{"\[Alpha]"},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}], 
     "=", 
     TemplateBox[{"\[Alpha]"},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}]}], 
   TraditionalForm]],ExpressionUUID->"bf78c6ef-5243-492e-9794-c30f81592d0f"],
 ")."
}], "Item",ExpressionUUID->"3b6e58bb-27bf-4afd-8050-3981f7d72165"],

Cell[TextData[{
 "Let ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPsi]"},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"74a30662-ce02-4656-8cda-d497794da7ee"],
 ", ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[CapitalPhi]"},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"27ef7bca-8948-43f1-81be-c8a56d010f27"],
 " be generic ",
 StyleBox["first-quantized states",
  FontSlant->"Italic"],
 " as in Eq. (",
 
 CounterBox["DisplayFormulaNumbered", "eq: 2678166479532444448"],
 "). "
}], "Item",ExpressionUUID->"10883ebe-efae-429d-8af2-034372339f08"]
}, Open  ]],

Cell[TextData[{
 "Now we define the ",
 StyleBox["insertion operator",
  FontWeight->"Bold"],
 " ",
