Cell["\<\
All the single-mode Fock state can be constructed by the boson creation \
operator from the vacuum state\
\>", "TextNoIndent",ExpressionUUID->"52735e17-e694-45b8-afc8-06a32ead7c59"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[{
     SubscriptBox["n", "\[Alpha]"]},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], "=", 
   RowBox[{
    FractionBox["1", 
     SqrtBox[
      RowBox[{
       SubscriptBox["n", "\[Alpha]"], "!"}]]], 
    SuperscriptBox[
     RowBox[{"(", 
      SubsuperscriptBox["b", "\[Alpha]", "\[Dagger]"], ")"}], 
     SubscriptBox["n", "\[Alpha]"]], 
    RowBox[{
     TemplateBox[{
       SubscriptBox["0", "\[Alpha]"]},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
     "."}]}]}], TraditionalForm]], "DisplayFormulaFramed",ExpressionUUID->\
"4cda94c6-690f-4d0f-bf28-b38cf0609a9b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Generic Fock States", "Subsubsubsection",ExpressionUUID->"b3f381f8-8e32-4edd-934b-0fefa65d9b9b"],

Cell["\<\
The above result can be generalized to any Fock state of bosons\
\>", "TextIndent",ExpressionUUID->"c27d010a-0829-487d-942d-51796cfb195b"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubsuperscriptBox["b", "\[Alpha]", "\[Dagger]"], 
     SubscriptBox[
      TemplateBox[{
        RowBox[{"\[Ellipsis]", ",", 
          SubscriptBox["n", "\[Beta]"], ",", 
          SubscriptBox["n", "\[Alpha]"], ",", 
          SubscriptBox["n", "\[Gamma]"], ",", "\[Ellipsis]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
      "B"]}], "=", 
    RowBox[{
     SqrtBox[
      RowBox[{
       SubscriptBox["n", "\[Alpha]"], "+", "1"}]], 
     SubscriptBox[
      TemplateBox[{
        RowBox[{"\[Ellipsis]", ",", 
          SubscriptBox["n", "\[Beta]"], ",", 
          RowBox[{
            SubscriptBox["n", "\[Alpha]"], "+", "1"}], ",", 
          SubscriptBox["n", "\[Gamma]"], ",", "\[Ellipsis]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
      "B"]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SubscriptBox["b", "\[Alpha]"], 
     SubscriptBox[
      TemplateBox[{
        RowBox[{"\[Ellipsis]", ",", 
          SubscriptBox["n", "\[Beta]"], ",", 
          SubscriptBox["n", "\[Alpha]"], ",", 
          SubscriptBox["n", "\[Gamma]"], ",", "\[Ellipsis]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
      "B"]}], "=", 
    RowBox[{
     SqrtBox[
      SubscriptBox["n", "\[Alpha]"]], 
     RowBox[{
      SubscriptBox[
       TemplateBox[{
         RowBox[{"\[Ellipsis]", ",", 
           SubscriptBox["n", "\[Beta]"], ",", 
           RowBox[{
             SubscriptBox["n", "\[Alpha]"], "-", "1"}], ",", 
           SubscriptBox["n", "\[Gamma]"], ",", "\[Ellipsis]"}]},
        "Ket",
        DisplayFunction->(
         RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
       "B"], "."}]}]}]}], TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "eq: 5515499843479260558",ExpressionUUID->"c3f9ed37-3ba5-4059-9702-\
6e2dc69dce83"],

Cell[TextData[{
 "These two equations can be considered as the ",
 StyleBox["defining properties",
  FontWeight->"Bold"],
