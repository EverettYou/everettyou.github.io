Cell[CellGroupData[{

Cell["Operator Identities", "Subsubsubsection",ExpressionUUID->"62fb69b8-3100-48eb-bfcc-9074c36e6ef6"],

Cell[TextData[{
 "Eq. (",
 
 CounterBox["DisplayFormulaNumbered", "eq: 5515499843479260558"],
 ") implies the following operator identities"
}], "TextIndent",ExpressionUUID->"f545ccc6-4460-4152-8067-0e479739d67a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubsuperscriptBox["b", "\[Alpha]", "\[Dagger]"], ",", 
      SubsuperscriptBox["b", "\[Beta]", "\[Dagger]"]}], "]"}], "=", 
    RowBox[{
     RowBox[{"[", 
      RowBox[{
       SubscriptBox["b", "\[Alpha]"], ",", 
       SubscriptBox["b", "\[Beta]"]}], "]"}], "=", "0"}]}], ",", " ", 
   RowBox[{
    RowBox[{"[", 
     RowBox[{
      SubscriptBox["b", "\[Alpha]"], ",", 
      SubsuperscriptBox["b", "\[Beta]", "\[Dagger]"]}], "]"}], "=", 
    RowBox[{
     SubscriptBox["\[Delta]", 
      RowBox[{"\[Alpha]", "\[VeryThinSpace]", "\[Beta]"}]], "."}]}]}], 
  TraditionalForm]], "DisplayFormulaFramed",ExpressionUUID->"716d532a-4a26-\
4771-9a6b-e639a1bca260"],

Cell[TextData[{
 "These relations can be considered as the ",
 StyleBox["algebraic definition",
  FontWeight->"Bold"],
 " of boson creation and annihilation operators."
}], "TextNoIndent",ExpressionUUID->"4f034f24-41ef-4d1c-bd60-b38260e5d44e"]
}, Open  ]]
}, Open  ]],

