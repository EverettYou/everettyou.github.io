  FontWeight->"Bold"],
 "."
}], "TextIndent",ExpressionUUID->"f932c6bf-d85e-41a2-9f66-4564f191f423"],

Cell[CellGroupData[{

Cell[TextData[{
 "The Fock state with all occupation numbers to be zero is called the ",
 StyleBox["vacuum state",
  FontWeight->"Bold"],
 ", denoted as"
}], "Item",ExpressionUUID->"c9d5a44f-1923-4d9a-9478-5b6890eba530"],

