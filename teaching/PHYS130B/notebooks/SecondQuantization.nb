     RowBox[{"0", ",", "14"}], "}"}]}], ",", 
   RowBox[{"FontFamily", "\[Rule]", "\"\<CMU\>\""}]}], "]"}]], "Input",
 CellLabel->
  "In[147]:=",ExpressionUUID->"68630331-3d0d-461f-bd7f-8f37f1df2c1c"],

