Cell[TextData[{
 "It turns out that ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[ScriptCapitalD]", "B"], "+", 
     SubscriptBox["\[ScriptCapitalD]", "F"]}], "\[LessEqual]", 
    "\[ScriptCapitalD]"}], TraditionalForm]],ExpressionUUID->
  "84fa6805-dc49-4fc8-82f3-efaa99dd1c5a"],
 " as long as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"N", ">", "1"}], TraditionalForm]],ExpressionUUID->
  "20beaee5-d91a-477b-b2e2-01a25171e611"],
 " \[Implies] the remaining basis states in the many-body Hilbert space are \
",
 StyleBox["unphysical",
  FontSlant->"Italic"],
 " (for identical particles). Is there a better way to organize the many-body \
Hilbert space, such that all states in the space are physical?"
}], "TextNoIndent",ExpressionUUID->"cf0cd537-35db-4d99-816a-4604ac9d7ba2"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Fock States and Fock Space", "Subsubsection",ExpressionUUID->"d0f6a3fc-f808-4eeb-a460-19532e3bf6c5"],

Cell[TextData[{
 "Sometimes, ",
 StyleBox["conceptual problems",
  FontSlant->"Italic"],
 " in physics arise from the ",
 StyleBox["inappropriate language",
  FontSlant->"Italic"],
 " we used. There are two different ways to describe many-body states:"
}], "TextIndent",ExpressionUUID->"a032455d-d7eb-47c3-a828-835fce583138"],

Cell[CellGroupData[{

Cell[TextData[{
 "In first-quantization, we ask: ",
 StyleBox["Which particle is in which state",
  FontSlant->"Italic"],
 "?"
}], "Item",ExpressionUUID->"7aa97ce8-2c98-4b9f-bf36-cbdf548a5044"],

Cell[TextData[{
 "In second-quantization, we ask: ",
 StyleBox["How many particles are there in every state",
  FontSlant->"Italic"],
 "?"
}], "Item",ExpressionUUID->"16fea75c-b91b-4d19-acef-39c7ea88cf8f"]
}, Open  ]],

Cell[TextData[{
 "The first question is inappropriate for ",
 StyleBox["identical",
  FontSlant->"Italic"],
 " particles: it is impossible to tell which particle is which in the first \
place. We need a new language:"
}], "TextNoIndent",ExpressionUUID->"aaf232c0-107f-48cc-96f0-69126ad19e78"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Style", "[", 
  RowBox[{
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "\"\<\\!\\(\[LeftBracketingBar]\[Alpha]\[RightAngleBracket]\
\[CircleTimes]\[LeftBracketingBar]\[Beta]\[RightAngleBracket]\\)\>\"", ",", 
         "\"\<\>\"", ",", 
         "\"\<\\!\\(\[LeftBracketingBar]\[Beta]\[RightAngleBracket]\
\[CircleTimes]\[LeftBracketingBar]\[Alpha]\[RightAngleBracket]\\)\>\""}], 
        "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
        "\"\<the 1st particle on \\!\\(\[LeftBracketingBar]\[Alpha]\
\[RightAngleBracket]\\)\\nthe 2nd particle in \\!\\(\[LeftBracketingBar]\
\[Beta]\[RightAngleBracket]\\)\>\"", ",", "\"\< \>\"", ",", 
         "\"\<the 1st particle on \\!\\(\[LeftBracketingBar]\[Beta]\
\[RightAngleBracket]\\)\\nthe 2nd particle in \\!\\(\[LeftBracketingBar]\
\[Alpha]\[RightAngleBracket]\\)\>\""}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
        "\"\<\[LowerRightArrow]\>\"", ",", "\"\< \>\"", ",", 
         "\"\<\[LowerLeftArrow]\>\""}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
        "\"\<there is one particle in \\!\\(\[LeftBracketingBar]\[Alpha]\
\[RightAngleBracket]\\), another particle in \
\\!\\(\[LeftBracketingBar]\[Beta]\[RightAngleBracket]\\)\>\"", ",", 
         "SpanFromLeft", ",", "SpanFromLeft"}], "}"}]}], "}"}], ",", 
     RowBox[{"Frame", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"None", ",", "None", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"2", ",", "1"}], "}"}], "\[Rule]", "True"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"2", ",", "3"}], "}"}], "\[Rule]", "True"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"4", ",", "1"}], "}"}], "\[Rule]", "True"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"4", ",", "2"}], "}"}], "\[Rule]", "True"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"4", ",", "3"}], "}"}], "\[Rule]", "True"}]}], "}"}]}], 
       "}"}]}], ",", 
     RowBox[{"Alignment", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Center", ",", "Center"}], "}"}]}]}], "]"}], ",", "14", ",", 
   RowBox[{"LineSpacing", "\[Rule]", 
    RowBox[{"{", 
     RowBox[{"0", ",", "14"}], "}"}]}], ",", 
   RowBox[{"FontFamily", "\[Rule]", "\"\<CMU\>\""}]}], "]"}]], "Input",Express\
ionUUID->"6c0d69ff-ff01-4681-a4a5-94b74116c0ce"],

Cell[BoxData[
 StyleBox[
  TagBox[GridBox[{
     {"\<\"\\!\\(\[LeftBracketingBar]\[Alpha]\[RightAngleBracket]\
\[CircleTimes]\[LeftBracketingBar]\[Beta]\[RightAngleBracket]\\)\"\>", \
