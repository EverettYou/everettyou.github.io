Notebook[{

Cell[CellGroupData[{
Cell["Quantum Mechanics", "Title",ExpressionUUID->"3c8ad64d-0f54-48ae-a066-84e52e5fe67e"],

Cell["Second Quantization", "Subtitle",ExpressionUUID->"996386ca-696e-493b-9c19-ede6ca0b43a8"],

Cell[CellGroupData[{

Cell["Second Quantization", "Section",ExpressionUUID->"00b0d44c-c2fa-40c0-b2f5-2d75103497b0"],

Cell[CellGroupData[{

Cell["Quantum Many-Body States", "Subsection",ExpressionUUID->"ca6949d5-0745-4146-94cb-faa22e6fe6c9"],

Cell[TextData[{
 StyleBox["Quantum many-body states",
  FontWeight->"Bold"],
 " describe the quantum system of many entities (particles). Depending on \
whether the particles are ",
 StyleBox["distinct",
  FontSlant->"Italic"],
 " or ",
 StyleBox["identical",
  FontSlant->"Italic"],
 ", quantum many-body systems can be divided into two classes:"
}], "TextIndent",ExpressionUUID->"45943c57-2932-42dc-92be-022c59740588"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["distinct",
  FontWeight->"Bold"],
 " particles: spins, qubits ..."
}], "Item",ExpressionUUID->"d4bb5926-3d54-4f55-88d2-a3c23fce0775"],

Cell[TextData[{
 StyleBox["identical",
  FontWeight->"Bold"],
 " particles: bosons, fermions ..."
}], "Item",ExpressionUUID->"630e8335-0ad5-49ac-8a2f-993f50e64fca"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Distinct Particles", "Subsubsection",ExpressionUUID->"685c49c7-9133-4e67-91fd-71572de3d42a"],

Cell[TextData[{
 StyleBox["Distinct particles",
  FontWeight->"Bold"],
 " can be ",
 StyleBox["labeled",
  FontSlant->"Italic"],
 ", such that we can specify the state of each particle, e.g. \
\[OpenCurlyDoubleQuote]the ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "d900121c-9cd5-45e5-b6e9-c4444640ece0"],
 "th particle is in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Alpha]", "i"], TraditionalForm]],ExpressionUUID->
  "d5820337-1452-417a-a886-509f8c92a3fc"],
 " state\[CloseCurlyDoubleQuote]."
}], "TextIndent",ExpressionUUID->"4205c9fa-d3d8-40f6-91bd-1571825556eb"],

Cell[CellGroupData[{

Cell[TextData[{
 "Suppose the ",
 StyleBox["single-particle Hilbert space",
  FontWeight->"Bold"],
 " is ",
 Cell[BoxData[
  FormBox["D", TraditionalForm]],ExpressionUUID->
  "16e58d4c-5a4e-499a-90b1-5c9b553f9049"],
 " dimensional, spanned by a set of orthonormal ",
 StyleBox["single-particle basis states",
  FontWeight->"Bold"],
 " ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{"\[Alpha]"},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"0af2557c-f97c-4f62-8488-12d72400d3f7"],
 " (",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[Alpha]", "=", "1"}], ",", "2", ",", "\[Ellipsis]", ",", "D"}], 
   TraditionalForm]],ExpressionUUID->"f50412d1-d504-4949-a163-f11d760fb90f"],
 ")."
}], "Item",ExpressionUUID->"ad7f2b77-6eca-4e7a-9d53-2bdd2ab9e639"],

Cell[TextData[{
 "The ",
 StyleBox["many-body Hilbert space",
  FontWeight->"Bold"],
 " of ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "8fe14456-1ff1-4412-8d99-c284dd182882"],
 " ",
 StyleBox["distinct",
  FontSlant->"Italic"],
 " particles will be ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["D", "N"], TraditionalForm]],ExpressionUUID->
  "ff162c48-e25a-48e1-b250-13638157d254"],
 " dimensional, spanned by the ",
 StyleBox["many-body basis states",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"8d175e13-3878-4550-86b6-fe93677f42f1"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    TemplateBox[{
      RowBox[{"[", "\[Alpha]", "]"}]},
     "Ket",
     DisplayFunction->(
      RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
    "\[Congruent]", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Alpha]", "1"]},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
     "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Alpha]", "2"]},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
     "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
     TemplateBox[{
       SubscriptBox["\[Alpha]", "N"]},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}]}], 
   ","}], TraditionalForm]], "DisplayFormulaFramed",ExpressionUUID->"26d6e09e-\
083b-4b04-a84a-a27ffede0411"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["\[Alpha]", "i"], "=", "1"}], ",", "2", ",", "\[Ellipsis]", 
    ",", "D"}], TraditionalForm]],ExpressionUUID->
  "c4e4d2b8-0d44-4028-a6d5-2e902880dc36"],
 " labels the state of the ",
 Cell[BoxData[
  FormBox["i", TraditionalForm]],ExpressionUUID->
  "cc4ea585-e152-4474-a244-07e5a68d1351"],
 "th particle."
}], "ItemParagraph",ExpressionUUID->"a679b5ca-8af9-4932-8007-92447376dfd0"],

Cell[TextData[{
 "A generic ",
 StyleBox["many-body state",
  FontWeight->"Bold"],
 " is a linear superposition of these basis states"
}], "Item",ExpressionUUID->"7ab6ee1f-6ce7-4120-a812-de7800ad7f3f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    TemplateBox[{"\[CapitalPsi]"},
     "Ket",
     DisplayFunction->(
      RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], "=", 
    RowBox[{
     UnderscriptBox["\[Sum]", 
      RowBox[{"[", "\[Alpha]", "]"}]], 
     RowBox[{
      RowBox[{"\[CapitalPsi]", "[", "\[Alpha]", "]"}], 
      TemplateBox[{
        RowBox[{"[", "\[Alpha]", "]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}]}]}],
    ","}], TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "eq: 2678166479532444448",ExpressionUUID->"045cdefb-470c-4578-9d4c-\
0a84de65eb7a"],

Cell[TextData[{
 "where the coefficient ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"\[CapitalPsi]", "[", "\[Alpha]", "]"}], "\[Element]", 
    "\[DoubleStruckCapitalC]"}], TraditionalForm]],ExpressionUUID->
  "4560f275-d646-49b5-bd64-46f0bd59798e"],
 " is also called the ",
 StyleBox["many-body wave function",
  FontWeight->"Bold"],
 "."
}], "ItemParagraph",ExpressionUUID->"deca14ce-e7df-4f7e-8023-7aac5e3b8691"],

Cell[TextData[{
 "The ",
 StyleBox["probability",
  FontWeight->"Bold"],
 " to find the many-body system in a specific state ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{"[", "\[Alpha]", "]"}]},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"8d7012c6-adaa-4281-a77d-d2aa0d38798b"],
 " is given by the absolute ",
 StyleBox["square",
  FontSlant->"Italic"],
 " of the ",
 StyleBox["many-body wave function",
  FontSlant->"Italic"],
 ","
}], "Item",ExpressionUUID->"de9e89d8-707f-4a33-92aa-a1730611bdf7"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["p", "\[CapitalPsi]"], "[", "\[Alpha]", "]"}], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      TemplateBox[{
        RowBox[{"[", "\[Alpha]", "]"}], "\[CapitalPsi]"},
       "BraKet",
       DisplayFunction->(
        RowBox[{"\[LeftAngleBracket]", #, "\[VerticalSeparator]", #2, 
          "\[RightAngleBracket]"}]& )], "\[RightBracketingBar]"}], "2"], "=", 
    
    RowBox[{
     SuperscriptBox[
      RowBox[{"\[LeftBracketingBar]", 
       RowBox[{"\[CapitalPsi]", "[", "\[Alpha]", "]"}], 
       "\[RightBracketingBar]"}], "2"], "."}]}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",
 CellTags->
  "eq: 1107742002833268259",ExpressionUUID->"e8ec30cf-cc4e-4d89-9fcf-\
a09dc382b76a"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Identical Particles", "Subsubsection",ExpressionUUID->"c1f67965-31a9-421f-9323-c1da769aa606"],

Cell[TextData[{
 StyleBox["Identical particles",
  FontWeight->"Bold"],
 " does not admit a labeling. Suppose we have a system of two particles, the \
following states are distinguishable only if we can label which particle is \
the 1st one and which is the 2nd one."
}], "TextIndent",ExpressionUUID->"0308a728-22ce-4edd-b0dd-0b1d55d0a1ac"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Style", "[", 
  RowBox[{
   RowBox[{"Grid", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "\"\<\\!\\(\[LeftBracketingBar]\[Alpha]\\_1\[RightAngleBracket]\
\[CircleTimes]\[LeftBracketingBar]\[Alpha]\\_2\[RightAngleBracket]\\)\>\"", 
         ",", "\"\<\>\"", ",", 
         "\"\<\\!\\(\[LeftBracketingBar]\[Alpha]\\_2\[RightAngleBracket]\
\[CircleTimes]\[LeftBracketingBar]\[Alpha]\\_1\[RightAngleBracket]\\)\>\""}], 
        "}"}], ",", 
       RowBox[{"{", 
        RowBox[{
        "\"\<the 1st particle on \\!\\(\[LeftBracketingBar]\[Alpha]\\_1\
\[RightAngleBracket]\\)\\nthe 2nd particle in \\!\\(\[LeftBracketingBar]\
\[Alpha]\\_2\[RightAngleBracket]\\)\>\"", ",", "\"\< \>\"", ",", 
         "\"\<the 1st particle on \\!\\(\[LeftBracketingBar]\[Alpha]\\_2\
\[RightAngleBracket]\\)\\nthe 2nd particle in \\!\\(\[LeftBracketingBar]\
\[Alpha]\\_1\[RightAngleBracket]\\)\>\""}], "}"}]}], "}"}], ",", 
     RowBox[{"Frame", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"None", ",", "None", ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"2", ",", "1"}], "}"}], "\[Rule]", "True"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"2", ",", "3"}], "}"}], "\[Rule]", "True"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"4", ",", "1"}], "}"}], "\[Rule]", "True"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"4", ",", "2"}], "}"}], "\[Rule]", "True"}], ",", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"4", ",", "3"}], "}"}], "\[Rule]", "True"}]}], "}"}]}], 
       "}"}]}], ",", 
     RowBox[{"Alignment", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Center", ",", "Center"}], "}"}]}]}], "]"}], ",", "14", ",", 
   RowBox[{"LineSpacing", "\[Rule]", 
