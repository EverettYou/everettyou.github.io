 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["\[ScriptCapitalD]", "B"], "=", 
    FractionBox[
     RowBox[{
      RowBox[{"(", 
       RowBox[{"N", "+", "D", "-", "1"}], ")"}], "!"}], 
     RowBox[{
      RowBox[{"N", "!"}], 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"D", "-", "1"}], ")"}], "!"}]}]]}], ","}], 
