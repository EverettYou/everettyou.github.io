Cell[TextData[{
 StyleBox["Pauli exclusion principle",
  FontWeight->"Bold"],
 ": two (or more) identical fermions can not occupy the same state \
simultaneously. "
}], "ItemParagraph",ExpressionUUID->"fc4d141a-6057-4434-a856-c208d46ce4b4"]
}, Open  ]],

Cell[TextData[{
 "For ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "1eba0f80-76c9-46b2-ae38-2650978859fe"],
 " particles, the Hilbert space dimension of"
}], "TextIndent",ExpressionUUID->"2b3dbb21-29ce-4561-8692-b5e08217d341"],

Cell[CellGroupData[{

Cell["the full space (of distinct particles):", "Item",ExpressionUUID->"c6efba9b-5813-4382-b4a9-4e57aa7941c1"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[ScriptCapitalD]", "=", 
