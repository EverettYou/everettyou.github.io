Cell[TextData[{
 "For identical particles, the above two scenarios are indistinguishable, \
meaning that it will be equally likely to observe the system in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox["\[Alpha]", "1"], 
       SubscriptBox["\[Alpha]", "2"]}]},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"c25351c8-6dca-40ce-9c91-b15c08f839dd"],
 " state as in ",
 Cell[BoxData[
  FormBox[
   TemplateBox[{
     RowBox[{
       SubscriptBox["\[Alpha]", "2"], 
       SubscriptBox["\[Alpha]", "1"]}]},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
   TraditionalForm]],ExpressionUUID->"fd4ed10a-c327-4302-ba18-c4e86ff49ce5"],
 " state."
}], "TextNoIndent",ExpressionUUID->"d3c4eca8-9557-4429-8c97-0b1efb2e793a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox["p", "\[CapitalPsi]"], "(", 
    RowBox[{
     SubscriptBox["\[Alpha]", "1"], ",", 
     SubscriptBox["\[Alpha]", "2"]}], ")"}], "=", 
   RowBox[{
    RowBox[{
     SubscriptBox["p", "\[CapitalPsi]"], "(", 
     RowBox[{
      SubscriptBox["\[Alpha]", "2"], ",", 
      SubscriptBox["\[Alpha]", "1"]}], ")"}], "."}]}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"387ab404-c873-\
4e20-b53c-df07b6505c29"],

Cell[TextData[{
 "Generalize to ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "a4e94524-cd6d-4e67-bc61-3c5ad2f080f2"],
 " particles, we introduce the ",
 StyleBox["permutation operator",
  FontSlant->"Italic"],
 " ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Pi]", "\[Element]", 
    SubscriptBox["S", "N"]}], TraditionalForm]],ExpressionUUID->
  "2006ec02-2467-4626-b967-405bc62ff8a4"],
 ", and denote the permuted state as"
}], "TextIndent",ExpressionUUID->"e0bac744-18c9-4e61-a9cf-061779b0de5a"],

Cell[BoxData[
 FormBox[
  RowBox[{
   TemplateBox[{
     RowBox[{"[", 
       SubscriptBox["\[Alpha]", "\[Pi]"], "]"}]},
    "Ket",
    DisplayFunction->(
     RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], "=", 
   RowBox[{
    TemplateBox[{
      SubscriptBox["\[Alpha]", 
       RowBox[{"\[Pi]", "(", "1", ")"}]]},
     "Ket",
     DisplayFunction->(
      RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
    "\[CircleTimes]", 
    TemplateBox[{
      SubscriptBox["\[Alpha]", 
       RowBox[{"\[Pi]", "(", "2", ")"}]]},
     "Ket",
     DisplayFunction->(
      RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
    "\[CircleTimes]", "\[Ellipsis]", "\[CircleTimes]", 
    RowBox[{
     TemplateBox[{
       SubscriptBox["\[Alpha]", 
        RowBox[{"\[Pi]", "(", "N", ")"}]]},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
     "."}]}]}], TraditionalForm]], "DisplayFormulaFramed",ExpressionUUID->\
"117e6815-ac8b-40db-90a4-f667d202f052"],

Cell[TextData[{
 "The requirement of identical particles imposes a ",
 StyleBox["permutation symmetry",
  FontSlant->"Italic"],
 " to the ",
 StyleBox["probability",
  FontSlant->"Italic"]
}], "TextNoIndent",ExpressionUUID->"e6683d93-dec2-4c60-a779-11a951480fe8"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"\[ForAll]", 
     RowBox[{"\[Pi]", "\[Element]", 
      RowBox[{
       SubscriptBox["S", "N"], ":", 
       RowBox[{
        SubscriptBox["p", "\[CapitalPsi]"], "[", "\[Alpha]", "]"}]}]}]}], "=", 
    RowBox[{
     SubscriptBox["p", "\[CapitalPsi]"], "[", 
     SubscriptBox["\[Alpha]", "\[Pi]"], "]"}]}], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"1dc16260-f257-\
4149-921f-72c07a7305e6"],

Cell[TextData[{
 "which, according to Eq. (",
 
 CounterBox["DisplayFormulaNumbered", "eq: 1107742002833268259"],
 "), is also a ",
 StyleBox["permutation symmetry",
  FontSlant->"Italic"],
 " of the ",
 StyleBox["many-body wave function",
  FontSlant->"Italic"],
 ","
}], "TextNoIndent",ExpressionUUID->"621fe1ae-4568-457e-81f8-a2c27e6c2bb0"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{"\[ForAll]", 
    RowBox[{"\[Pi]", "\[Element]", 
     RowBox[{
      SubscriptBox["S", "N"], ":", 
      SuperscriptBox[
       RowBox[{"\[LeftBracketingBar]", 
        RowBox[{"\[CapitalPsi]", "[", "\[Alpha]", "]"}], 
        "\[RightBracketingBar]"}], "2"]}]}]}], "=", 
   RowBox[{
    SuperscriptBox[
     RowBox[{"\[LeftBracketingBar]", 
      RowBox[{"\[CapitalPsi]", "[", 
       SubscriptBox["\[Alpha]", "\[Pi]"], "]"}], "\[RightBracketingBar]"}], 
     "2"], "."}]}], TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID\
->"fc18f855-67da-4803-b038-5bd486bce0f1"],

Cell[TextData[{
 "The wave function can only change up to an ",
 StyleBox["overall phase factor",
  FontSlant->"Italic"],
 "."
}], "TextNoIndent",ExpressionUUID->"2620d77e-f976-4dd5-b436-86f6de9bc18c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{"\[CapitalPsi]", "[", "\[Alpha]", "]"}], "=", 
    RowBox[{
     SuperscriptBox["e", 
      RowBox[{"\[ImaginaryI]", " ", "\[CurlyPhi]"}]], 
     RowBox[{"\[CapitalPsi]", "[", 
      SubscriptBox["\[Alpha]", "\[Pi]"], "]"}]}]}], ","}], 
  TraditionalForm]], "DisplayFormulaNumbered",ExpressionUUID->"3bdd8784-1cce-\
482b-9b05-48f572abaee3"],

Cell[TextData[{
 "It forms a ",
 StyleBox["one-dimensional representation",
  FontWeight->"Bold"],
 " of the ",
 StyleBox["permutation group",
  FontWeight->"Bold"],
 ". ",
 StyleBox["Mathematical fact", "TextConcreteNoIndent"],
 ": there are only ",
 StyleBox["two",
  FontSlant->"Italic"],
 " 1-dim representations of any permutation group,"
}], "TextNoIndent",ExpressionUUID->"bc620517-38b1-4710-b5fd-378acbeb647f"],

Cell[CellGroupData[{

Cell[TextData[{
 StyleBox["symmetric",
  FontWeight->"Bold"],
 " (trivial) representation \[Implies] ",
 StyleBox["bosons",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"b5f1cfe0-4ee9-4218-8846-fa13fdbb3216"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalPsi]", "B"], "[", "\[Alpha]", "]"}], "=", 
    RowBox[{
     SubscriptBox["\[CapitalPsi]", "B"], "[", 
     SubscriptBox["\[Alpha]", "\[Pi]"], "]"}]}], ","}], 
  TraditionalForm]], "DisplayFormulaFramed",ExpressionUUID->"210e7d4a-8346-\
4c80-b950-1f644226687c"],

Cell[TextData[{
 StyleBox["antisymmetric",
  FontWeight->"Bold"],
 " (sign) representation \[Implies] ",
 StyleBox["fermions",
  FontWeight->"Bold"]
}], "Item",ExpressionUUID->"7f2b5218-25d9-4b3e-af3e-4963c406f426"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubscriptBox["\[CapitalPsi]", "F"], "[", "\[Alpha]", "]"}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", "-", ")"}], "\[Pi]"], 
     RowBox[{
      SubscriptBox["\[CapitalPsi]", "F"], "[", 
      SubscriptBox["\[Alpha]", "\[Pi]"], "]"}]}]}], ","}], 
  TraditionalForm]], "DisplayFormulaFramed",ExpressionUUID->"b3c210f9-3eec-\
44e5-b538-cdc491e52889"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox[
    RowBox[{"(", "-", ")"}], "\[Pi]"], TraditionalForm]],ExpressionUUID->
  "2f7b05ee-804e-4c20-bf6e-8b2fff4335a5"],
 " denotes the ",
 StyleBox["permutation sign",
  FontWeight->"Bold"],
 " of ",
 Cell[BoxData[
  FormBox["\[Pi]", TraditionalForm]],ExpressionUUID->
  "a7f23bdc-2300-471e-bdbd-4049748a7565"]
}], "ItemParagraph",ExpressionUUID->"d0ad7d82-dc34-491c-a147-96b46a2579cd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox[
    RowBox[{"(", "-", ")"}], "\[Pi]"], "=", 
   TagBox[GridBox[{
      {"\[Piecewise]", GridBox[{
         {
          RowBox[{"+", "1"}], 
          RowBox[{
           RowBox[{
           "if", " ", "\[Pi]", " ", "contains", " ", "even", " ", "number", 
            " ", "of", " ", "exchanges"}], ","}]},
         {
          RowBox[{"-", "1"}], 
          RowBox[{
          "if", " ", "\[Pi]", " ", "contains", " ", "odd", " ", "number", " ",
            "of", " ", 
           RowBox[{"exchanges", "."}]}]}
        },
