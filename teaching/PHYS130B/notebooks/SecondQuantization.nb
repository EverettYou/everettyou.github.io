 " is involved), the first-quantized state will involve appropriate \
symmetrization depending on the particle statistics. For example,"
}], "Item",ExpressionUUID->"0770b162-eda6-4a66-962a-66fecade446c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    SubscriptBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["1", "\[Alpha]"], ",", 
         SubscriptBox["1", "\[Beta]"]}]},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], "B"], 
    "=", 
