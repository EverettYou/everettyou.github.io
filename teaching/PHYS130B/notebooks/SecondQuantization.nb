          RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )]}]}],
       ")"}]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    SubscriptBox[
     TemplateBox[{
       RowBox[{
         SubscriptBox["1", "\[Alpha]"], ",", 
         SubscriptBox["1", "\[Beta]"]}]},
      "Ket",
      DisplayFunction->(
       RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], "F"], 
    "=", 
    RowBox[{
     FractionBox["1", 
      SqrtBox["2"]], 
     RowBox[{
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         TemplateBox[{"\[Alpha]"},
          "Ket",
          
          DisplayFunction->(
           RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
         "\[CircleTimes]", 
         TemplateBox[{"\[Beta]"},
          "Ket",
          
