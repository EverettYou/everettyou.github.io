Cell[CellGroupData[{

Cell["Generic Fock States", "Subsubsubsection",ExpressionUUID->"283b4e9e-5b71-4a1d-b180-680197e20537"],

Cell["\<\
The above result can be generalized to any Fock state of bosons\
\>", "TextIndent",ExpressionUUID->"84e99004-8aa4-43f4-bac9-67cc929e3972"],

Cell[BoxData[
 FormBox[
  RowBox[{
   RowBox[{
    RowBox[{
     SubsuperscriptBox["c", "\[Alpha]", "\[Dagger]"], 
     SubscriptBox[
      TemplateBox[{
        RowBox[{"\[Ellipsis]", ",", 
          SubscriptBox["n", "\[Beta]"], ",", 
          SubscriptBox["n", "\[Alpha]"], ",", 
          SubscriptBox["n", "\[Gamma]"], ",", "\[Ellipsis]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
      "F"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", "-", ")"}], 
      RowBox[{
       SubscriptBox["\[Sum]", 
        RowBox[{"\[Beta]", "<", "\[Alpha]"}]], 
       SubscriptBox["n", "\[Beta]"]}]], 
     SqrtBox[
      RowBox[{"1", "-", 
       SubscriptBox["n", "\[Alpha]"]}]], 
     SubscriptBox[
      TemplateBox[{
        RowBox[{"\[Ellipsis]", ",", 
          SubscriptBox["n", "\[Beta]"], ",", 
          RowBox[{"1", "-", 
            SubscriptBox["n", "\[Alpha]"]}], ",", 
          SubscriptBox["n", "\[Gamma]"], ",", "\[Ellipsis]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
      "F"]}]}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     SubscriptBox["c", "\[Alpha]"], 
     SubscriptBox[
      TemplateBox[{
        RowBox[{"\[Ellipsis]", ",", 
          SubscriptBox["n", "\[Beta]"], ",", 
          SubscriptBox["n", "\[Alpha]"], ",", 
          SubscriptBox["n", "\[Gamma]"], ",", "\[Ellipsis]"}]},
       "Ket",
       DisplayFunction->(
        RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
      "F"]}], "=", 
    RowBox[{
     SuperscriptBox[
      RowBox[{"(", "-", ")"}], 
      RowBox[{
       SubscriptBox["\[Sum]", 
        RowBox[{"\[Beta]", "<", "\[Alpha]"}]], 
       SubscriptBox["n", "\[Beta]"]}]], 
     SqrtBox[
      SubscriptBox["n", "\[Alpha]"]], 
     RowBox[{
      SubscriptBox[
       TemplateBox[{
         RowBox[{"\[Ellipsis]", ",", 
           SubscriptBox["n", "\[Beta]"], ",", 
           RowBox[{"1", "-", 
             SubscriptBox["n", "\[Alpha]"]}], ",", 
           SubscriptBox["n", "\[Gamma]"], ",", "\[Ellipsis]"}]},
        "Ket",
        DisplayFunction->(
         RowBox[{"\[LeftBracketingBar]", #, "\[RightAngleBracket]"}]& )], 
       "F"], "."}]}]}]}], TraditionalForm]], "DisplayFormulaFramed",
 CellTags->
  "eq: 2438092776105532924",ExpressionUUID->"12ee1ee8-ab33-456d-9856-\
31391d01723d"],

