Cell["2.3.1 Braid Group", "Subsubsection",ExpressionUUID->"d0cdfd85-78b2-4260-8c70-4086cf84f4d5"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Block", "[", 
  RowBox[{
   RowBox[{"{", "braid", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"braid", "[", 
      RowBox[{"ids_", ",", "n_"}], "]"}], ":=", 
     RowBox[{"Block", "[", 
      RowBox[{
       RowBox[{"{", "sigma", "}"}], ",", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{
         RowBox[{"sigma", "[", "i_", "]"}], ":=", 
         RowBox[{"Block", "[", 
          RowBox[{
           RowBox[{"{", "f", "}"}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"f", "=", 
             RowBox[{"BSplineFunction", "[", 
              RowBox[{"Table", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"x", ",", 
                  RowBox[{"Piecewise", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"0", ",", 
                    RowBox[{"x", "<", "0.2"}]}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", 
                    RowBox[{"x", ">", "0.8"}]}], "}"}]}], "}"}], ",", 
                    RowBox[{"0.5", 
                    RowBox[{"(", 
                    RowBox[{
                    RowBox[{"Tanh", "[", 
                    RowBox[{"5", 
                    RowBox[{"(", 
                    RowBox[{"x", "-", "0.5"}], ")"}]}], "]"}], "+", "1"}], 
                    ")"}]}]}], "]"}]}], "}"}], ",", 
                RowBox[{"{", 
                 RowBox[{"x", ",", "0", ",", "1", ",", "0.1"}], "}"}]}], 
               "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"Translate", "[", 
                 RowBox[{
                  RowBox[{"Line", "[", 
                   RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"#", ",", "0"}], "}"}], "&"}], "/@", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", "1"}], "}"}]}], "]"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", "#"}], "}"}]}], "]"}], "&"}], "/@", 
               RowBox[{"Complement", "[", 
                RowBox[{
                 RowBox[{"Range", "[", "n", "]"}], ",", 
                 RowBox[{"{", 
                  RowBox[{"i", ",", 
                   RowBox[{"i", "+", "1"}]}], "}"}]}], "]"}]}], ",", 
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{"i", ">", "0"}], ",", 
                RowBox[{"Translate", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"Line", "[", 
                    RowBox[{"f", "/@", 
                    RowBox[{"Range", "[", 
                    RowBox[{"0", ",", "0.4", ",", "0.02"}], "]"}]}], "]"}], 
                    ",", 
                    RowBox[{"Line", "[", 
                    RowBox[{"f", "/@", 
                    RowBox[{"Range", "[", 
                    RowBox[{"0.6", ",", "1", ",", "0.02"}], "]"}]}], "]"}]}], 
                    "}"}], ",", 
                    RowBox[{"Scale", "[", 
                    RowBox[{
                    RowBox[{"Line", "[", 
                    RowBox[{"f", "/@", 
                    RowBox[{"Range", "[", 
                    RowBox[{"0", ",", "1", ",", "0.02"}], "]"}]}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"1", ",", 
                    RowBox[{"-", "1"}]}], "}"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"0.5", ",", "0.5"}], "}"}]}], "]"}]}], "}"}], ",", 
                  RowBox[{"{", 
                   RowBox[{"0", ",", "i"}], "}"}]}], "]"}]}], "]"}]}], 
             "}"}]}]}], "]"}]}], ";", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"MapIndexed", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Translate", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"sigma", "[", "#1", "]"}], ",", 
                 RowBox[{"Text", "[", 
                  RowBox[{
                   RowBox[{"If", "[", 
                    RowBox[{
                    RowBox[{"#1", ">", "0"}], ",", 
                    RowBox[{
                    RowBox[{
                    "StringTemplate", "[", 
                    "\"\<\\!\\(\[ScriptCapitalP]\\&^\\_\\(`1``2`\\)\\)\>\"", 
                    "]"}], "[", 
                    RowBox[{"#1", ",", 
                    RowBox[{"#1", "+", "1"}]}], "]"}], ",", "\"\<\>\""}], 
                    "]"}], ",", 
                   RowBox[{"{", 
                    RowBox[{"0.5", ",", "0.5"}], "}"}]}], "]"}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"First", "@", "#2"}], ",", "0"}], "}"}]}], "]"}], 
             "&"}], ",", "ids"}], "]"}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"Translate", "[", 
             RowBox[{
              RowBox[{"Point", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"{", 
                  RowBox[{"1", ",", "#"}], "}"}], "&"}], "/@", 
                RowBox[{"Range", "[", "n", "]"}]}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"#", ",", "0"}], "}"}]}], "]"}], "&"}], "/@", 
           RowBox[{"{", 
            RowBox[{"0", ",", 
             RowBox[{"Length", "[", "ids", "]"}]}], "}"}]}]}], "}"}]}]}], 
      "]"}]}], ";", "\[IndentingNewLine]", 
    RowBox[{"Graphics", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Translate", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Translate", "[", 
             RowBox[{
              RowBox[{"braid", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"1", ",", "1"}], "}"}], ",", "2"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "3.5"}], ",", "0"}], "}"}]}], "]"}], ",", 
            RowBox[{"Text", "[", 
             RowBox[{
              RowBox[{"Style", "[", 
               RowBox[{"\"\<\\!\\(\[NotEqual]\\)\>\"", ",", "18"}], "]"}], 
              ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "1.5"}], "}"}]}], "]"}], ",", 
            RowBox[{"Text", "[", 
             RowBox[{"\"\<\\!\\(\[DoubleStruckOne]\\)\>\"", ",", 
              RowBox[{"{", 
               RowBox[{"1.5", ",", "0.5"}], "}"}]}], "]"}], ",", 
            RowBox[{"Translate", "[", 
             RowBox[{
              RowBox[{"braid", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{
                  RowBox[{"-", "1"}], ",", 
                  RowBox[{"-", "1"}]}], "}"}], ",", "2"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.5"}], ",", "0"}], "}"}]}], "]"}]}], "}"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "3.5"}], "}"}]}], "]"}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"Translate", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"Translate", "[", 
             RowBox[{
              RowBox[{"braid", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"1", ",", "2", ",", "1"}], "}"}], ",", "3"}], "]"}], 
              ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "4.5"}], ",", "0"}], "}"}]}], "]"}], ",", 
            RowBox[{"Text", "[", 
             RowBox[{
              RowBox[{"Style", "[", 
               RowBox[{"\"\<\\!\\(=\\)\>\"", ",", "18"}], "]"}], ",", 
              RowBox[{"{", 
               RowBox[{"0", ",", "2"}], "}"}]}], "]"}], ",", 
            RowBox[{"Translate", "[", 
             RowBox[{
              RowBox[{"braid", "[", 
               RowBox[{
                RowBox[{"{", 
                 RowBox[{"2", ",", "1", ",", "2"}], "}"}], ",", "3"}], "]"}], 
              ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.5"}], ",", "0"}], "}"}]}], "]"}]}], "}"}], 
          ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", "0"}], "}"}]}], "]"}]}], "}"}], ",", 
      RowBox[{"PlotRangePadding", "->", 
       RowBox[{"Scaled", "[", ".05", "]"}]}], ",", 
      RowBox[{"ImageSize", "->", "200"}]}], "]"}]}]}], "\[IndentingNewLine]", 
  "]"}]], "Input",
